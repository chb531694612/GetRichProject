# Data source
DATA_PROVIDER=okooo
OKOOO_BASE_URL=https://www.okooo.com
SPORTTERY_ODDS_URL=https://webapi.sporttery.cn/gateway/jc/football/getMatchCalculatorV1.qry
SPORTTERY_RESULTS_URL=https://webapi.sporttery.cn/gateway/uniform/football/getUniformMatchResultV1.qry
JSON_DATA_FILE=examples/demo-data.json

# Recommendation strategy
TIMEZONE=Asia/Shanghai
AUTOMATIC_ANALYSIS_ENABLED=true
POISSON_MODEL_WEIGHT=0.35
MIN_LEAD_MINUTES=60
MAX_LOOKAHEAD_HOURS=48
MAX_ODDS_AGE_MINUTES=120
# Historical reference only; v0.7.0 strategy no longer filters on these values.
MIN_SCORE_PROBABILITY=0.02
MIN_JOINT_PROBABILITY=0.0001
MAX_MATCHES_PER_LEAGUE=2
ALLOW_OTHER_SCORES=false
MAX_PLANS_PER_BUSINESS_DATE=1
SEND_NO_RECOMMENDATION=true
RECOMMENDATION_TIMES=10:00,14:00,17:30
RECOMMENDATION_FIRST_MAIL_TIME=15:00
RECOMMENDATION_LATEST_START=17:45
RECOMMENDATION_DEADLINE=18:00
RECOMMENDATION_SEND_BUFFER_MINUTES=10

# Runtime
DATABASE_PATH=data/score_fourfold.db
POLL_INTERVAL_SECONDS=1800
RESULT_CHECK_DELAY_MINUTES=150
HTTP_TIMEOUT_SECONDS=20

# Dashboard
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_ACCESS_MODE=ssh
WEB_PUBLIC_ORIGIN=
WEB_USERNAME=owner
WEB_PASSWORD_HASH=
WEB_TRUST_PROXY_HEADERS=false
WEB_SESSION_HOURS=12

# HAD market
HAD_ENABLED=true
HAD_PASS_SIZES=6,5,4
# Historical reference only; v0.7.0 strategy no longer filters on these values.
MIN_HAD_PROBABILITY=0.28
MIN_HAD_JOINT_PROBABILITY=0.01

# Optional Alibaba Cloud Model Studio Qwen analysis with mandatory web search.
AI_ANALYSIS_ENABLED=false
AI_HTTP_TIMEOUT_SECONDS=600
QWEN_API_KEY=
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/responses
QWEN_MODEL=qwen3.7-max

# QQ mail. Keep real credentials only in the server-side .env file.
MAIL_TO=531694612@qq.com
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_AUTH_CODE=
MAIL_FROM=
MAIL_DRY_RUN=true
MAIL_PREVIEW_DIR=data/mail-preview
